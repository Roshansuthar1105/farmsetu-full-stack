# ==========================================
# FarmSetu GitIgnore Configuration
# ==========================================

# ------------------------------------------
# Operating System Files
# ------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux / Unix
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------------------------------
# IDEs & Text Editors
# ------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# Eclipse
.metadata/
.classpath
.project
.settings/
*.launch
.factorypath
bin/

# NetBeans
**/nbproject/private/
**/nbbuild/
**/dist/
**/nbproject/Makefile-*.mk
**/nbproject/Package-*.bash

# Miscellaneous editor files
*.swp
*.swo
*~

# ------------------------------------------
# Build Tools & Package Managers
# ------------------------------------------
node_modules/
/node_modules/
/farmsetu-frontend/node_modules/

# ------------------------------------------
# Angular Frontend (farmsetu-frontend)
# ------------------------------------------
/farmsetu-frontend/dist/
/farmsetu-frontend/tmp/
/farmsetu-frontend/out-tsc/
/farmsetu-frontend/.angular/
/farmsetu-frontend/.sass-cache/
/farmsetu-frontend/connect.lock
/farmsetu-frontend/coverage/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Angular Local environment files
# (API keys for Twilio, Razorpay, Maps, OpenAI, OpenWeatherMap, Firebase)
/farmsetu-frontend/src/environments/environment.development.ts
/farmsetu-frontend/src/environments/environment.production.ts
/farmsetu-frontend/src/environments/environment.local.ts

# db
./database/*
# ------------------------------------------
# Spring Boot Backend (farmsetu-backend)
# ------------------------------------------
/farmsetu-backend/target/
/farmsetu-backend/bin/
/farmsetu-backend/out/
/farmsetu-backend/.gradle/
/farmsetu-backend/build/
application.properties
# Compiled Java class files
*.class
/farmsetu-backend/**/*.class

# Log files
/farmsetu-backend/*.log
/farmsetu-backend/logs/

# Maven-specific files
/farmsetu-backend/pom.xml.tag
/farmsetu-backend/pom.xml.releaseBackup
/farmsetu-backend/pom.xml.versionsBackup
/farmsetu-backend/pom.xml.next
/farmsetu-backend/release.properties
/farmsetu-backend/dependency-reduced-pom.xml
/farmsetu-backend/buildNumber.properties
/farmsetu-backend/.mvn/timing.properties

# Maven wrapper
# Keep the wrapper jar if you use it, or comment out to ignore it
# !/farmsetu-backend/.mvn/wrapper/maven-wrapper.jar

# ------------------------------------------
# Secrets, Configurations & Credentials
# ------------------------------------------
# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Spring Boot Configuration Secrets (sensitive Postgres/Redis/API secrets)
/farmsetu-backend/src/main/resources/application.properties
/farmsetu-backend/src/main/resources/application-*.properties
/farmsetu-backend/src/main/resources/application-*.yml
/farmsetu-backend/src/main/resources/application-*.yaml

# Explicitly track sample config files if you create them
!/farmsetu-backend/src/main/resources/application.properties.example
!/farmsetu-backend/src/main/resources/application-sample.properties
!/farmsetu-backend/src/main/resources/application-sample.yml
!/farmsetu-backend/src/main/resources/application-sample.yaml

# Firebase service account credentials
*firebase-auth*.json
*firebase-adminsdk*.json
*serviceAccountKey.json
google-services.json

# ------------------------------------------
# Diagnostic and Crash Reports
# ------------------------------------------
hs_err_pid*
replay_pid*







