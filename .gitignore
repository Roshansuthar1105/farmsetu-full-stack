# ==========================================
# FarmSetu GitIgnore Configuration
# ==========================================

# ------------------------------------------
# Operating System Files
# ------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux / Unix
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------------------------------
# IDEs & Text Editors
# ------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# Eclipse
.metadata/
.classpath
.project
.settings/
*.launch
.factorypath
bin/

# NetBeans
**/nbproject/private/
**/nbbuild/
**/dist/
**/nbproject/Makefile-*.mk
**/nbproject/Package-*.bash

# Miscellaneous editor files
*.swp
*.swo
*~

# ------------------------------------------
# Build Tools & Package Managers
# ------------------------------------------
node_modules/
/node_modules/
/frontend/node_modules/

# ------------------------------------------
# Angular Frontend (frontend)
# ------------------------------------------
/frontend/dist/
/frontend/tmp/
/frontend/out-tsc/
/frontend/.angular/
/frontend/.sass-cache/
/frontend/connect.lock
/frontend/coverage/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Angular Local environment files
# (API keys for Twilio, Razorpay, Maps, OpenAI, OpenWeatherMap, Firebase)
/frontend/src/environments/environment.development.ts
/frontend/src/environments/environment.production.ts
/frontend/src/environments/environment.local.ts

# db
./database/*
# ------------------------------------------
# Spring Boot Backend (backend)
# ------------------------------------------
/backend/target/
/backend/bin/
/backend/out/
/backend/.gradle/
/backend/build/
# Compiled Java class files
*.class
/backend/**/*.class

# Log files
/backend/*.log
/backend/logs/

# Maven-specific files
/backend/pom.xml.tag
/backend/pom.xml.releaseBackup
/backend/pom.xml.versionsBackup
/backend/pom.xml.next
/backend/release.properties
/backend/dependency-reduced-pom.xml
/backend/buildNumber.properties
/backend/.mvn/timing.properties

# Maven wrapper
# Keep the wrapper jar if you use it, or comment out to ignore it
# !/backend/.mvn/wrapper/maven-wrapper.jar

# ------------------------------------------
# Secrets, Configurations & Credentials
# ------------------------------------------
# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Spring Boot Configuration Secrets (sensitive Postgres/Redis/API secrets)
/backend/src/main/resources/application-*.properties
/backend/src/main/resources/application-*.yml
/backend/src/main/resources/application-*.yaml

# Explicitly track sample config files if you create them
!/backend/src/main/resources/application-sample.properties
!/backend/src/main/resources/application-sample.yml
!/backend/src/main/resources/application-sample.yaml

# Firebase service account credentials
*firebase-auth*.json
*firebase-adminsdk*.json
*serviceAccountKey.json
google-services.json

# ------------------------------------------
# Diagnostic and Crash Reports
# ------------------------------------------
hs_err_pid*
replay_pid*

.sql
api_docs.md
developer_rules.md
./txt
.clinerules
Farmsetu.txt

.angular
.env